# Enable third-party markitdown plugins (disabled by default upstream)
MARKITDOWN_ENABLE_PLUGINS=false

# Optional: when set, all endpoints except /health require this value as a Bearer token.
# When unset, endpoints are unauthenticated.
MARKITDOWN_FASTAPI_TOKEN=

# Optional: Azure Document Intelligence endpoint for higher-quality PDF/office parsing
AZURE_DOCINTEL_ENDPOINT=

# Optional: LLM used for image captioning during conversion
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# Max upload size in bytes for /api/v1/convert
MAX_UPLOAD_SIZE_BYTES=52428800
